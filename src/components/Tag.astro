---
export interface Props {
  label: string;
  accent?: boolean;
}
const { label, accent = false } = Astro.props;
---
<span class:list={[
  "inline-block text-[11px] uppercase tracking-wider px-2.5 py-1 rounded-full border",
  accent
    ? "border-neutral-900 text-neutral-900"
    : "border-neutral-200 text-neutral-400"
]}>
  {label}
</span>
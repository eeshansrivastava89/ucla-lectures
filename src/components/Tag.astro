---
export interface Props {
  label: string;
  accent?: boolean;
}
const { label, accent = false } = Astro.props;
---
<span class:list={[
  "inline-block text-[11px] uppercase tracking-wider px-2.5 py-1 rounded-full border",
]} style={accent
  ? { borderColor: 'var(--border-strong)', color: 'var(--fg)' }
  : { borderColor: 'var(--border)', color: 'var(--fg-faint)' }
}>
  {label}
</span>
---
import siteData from '../data/site.json';

export interface Props {
  current: string;
}
const { current } = Astro.props;
const brand = siteData.brand;
const nav = siteData.nav;
---
<button id="sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-50 w-10 h-10 flex items-center justify-center rounded bg-white border-2 border-black text-black hover:bg-black hover:text-white transition-colors" aria-label="Menu">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
</button>

<div id="sidebar-backdrop" class="lg:hidden fixed inset-0 bg-black/40 z-30 hidden"></div>

<aside id="sidebar" class="fixed top-0 left-0 bottom-0 w-64 bg-white border-r-2 border-black z-40 overflow-y-auto transition-transform lg:translate-x-0 -translate-x-full lg:block">
  <div class="px-6 pt-8 pb-4">
    <a href="/" class="block">
      <span class="text-base font-bold tracking-tight text-black">{brand.short.split(' · ')[0]}</span>
      <span class="text-neutral-400 font-light"> · </span>
      <span class="text-base font-bold tracking-tight text-black">{brand.short.split(' · ')[1]}</span>
    </a>
    <p class="text-[11px] text-neutral-500 font-medium mt-0.5">{brand.program}</p>
  </div>

  <nav class="px-3 space-y-0.5">
    {nav.map((item: any) => {
      if (item.type === 'divider') {
        return <div class="border-t border-neutral-200 my-3" />;
      }
      const isActive = current === item.id;
      return (
        <a
          href={item.href}
          class:list={[
            "block px-3 py-2.5 rounded-md text-sm font-medium transition-colors",
            isActive
              ? "bg-black text-white"
              : "text-neutral-700 hover:text-black hover:bg-neutral-100",
          ]}
        >
          {item.label}
        </a>
      );
    })}
  </nav>

  <div class="absolute bottom-0 left-0 right-0 p-4 border-t-2 border-black">
    <p class="text-xs font-semibold text-black">{brand.instructor}</p>
    <a href={brand.instructorUrl} class="text-xs text-neutral-500 hover:text-black transition-colors font-medium">{brand.instructorUrl.replace('https://', '')}</a>
  </div>
</aside>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');
  function open() { sidebar?.classList.remove('-translate-x-full'); backdrop?.classList.remove('hidden'); }
  function close() { sidebar?.classList.add('-translate-x-full'); backdrop?.classList.add('hidden'); }
  toggle?.addEventListener('click', () => sidebar?.classList.contains('-translate-x-full') ? open() : close());
  backdrop?.addEventListener('click', close);
</script>
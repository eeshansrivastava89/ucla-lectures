---
import Course from '../../layouts/Course.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const lectures = (await getCollection('pages'))
    .filter((p: any) => p.id.startsWith('lecture-'))
    .sort((a: any, b: any) => a.id.localeCompare(b.id));

  return lectures.map((lecture: any, index: number) => ({
    params: { id: lecture.id.replace('lecture-', '') },
    props: { lecture, index, lectures },
  }));
}

const { lecture, index, lectures } = Astro.props;
const { Content } = await render(lecture);
const d = lecture.data;
const h = d.sectionHeadings;
const prev = index > 0 ? lectures[index - 1] : null;
const next = index < lectures.length - 1 ? lectures[index + 1] : null;
---
<Course title={`Lecture ${d.icon} — ${d.title}`} current={`lecture-${Astro.params.id}`}>

  <p class="text-[11px] uppercase tracking-[0.2em] font-bold mb-2" style="color: var(--fg-muted);">Lecture {d.icon}</p>
  <h1 class="text-3xl font-bold tracking-tight mb-2" style="color: var(--fg);">{d.title}</h1>
  <p class="font-medium mb-8" style="color: var(--fg-secondary);">{d.tagline}</p>

  <section class="mb-10">
    <h2 class="section-heading">{h.deliverable}</h2>
    <div class="rounded p-5" style="border: 2px solid var(--border-strong); background-color: var(--bg-card);">
      <p class="text-[15px] font-semibold" style="color: var(--bg);">{d.deliverable}</p>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.handsOn}</h2>
    <div class="rounded p-5" style="border: 2px solid var(--border-strong);">
      <p class="text-[15px] mb-3" style="color: var(--fg-secondary);">{d.handsOn}</p>
      <div class="flex flex-wrap gap-2">
        {d.tools.map((t: string) => (
          <span class="text-[12px] font-bold px-2.5 py-1 rounded" style="background-color: var(--nav-active-bg); color: var(--nav-active-fg);">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.concept}</h2>
    <div class="prose-course">
      <Content />
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.topics}</h2>
    <ul class="space-y-2">
      {d.topics.map((t: string) => (
        <li class="flex items-start gap-3 text-[15px]" style="color: var(--fg-secondary);">
          <span class="w-2 h-2 rounded-full mt-1.5 shrink-0" style="background-color: var(--dot-color);"></span>
          <span>{t}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.bigTech}</h2>
    <div class="rounded p-5" style="border: 2px solid var(--border); background-color: var(--bg-inset);">
      <p class="text-[15px]" style="color: var(--fg-secondary);">{d.bigTech}</p>
    </div>
  </section>

  <div class="flex justify-between items-center pt-8" style="border-top: 2px solid var(--border-strong);">
    {prev ? (
      <a href={`lectures/${prev.id.replace('lecture-', '')}`} class="text-sm font-semibold transition-colors" style="color: var(--fg-muted);" onmouseover="this.style.color='var(--fg)';" onmouseout="this.style.color='var(--fg-muted)';">← {prev.data.prevNav || `${prev.data.icon} · ${prev.data.title}`}</a>
    ) : <div />}
    {next ? (
      <a href={`lectures/${next.id.replace('lecture-', '')}`} class="text-sm font-semibold transition-colors" style="color: var(--fg-muted);" onmouseover="this.style.color='var(--fg)';" onmouseout="this.style.color='var(--fg-muted)';">{d.nextNav || `${next.data.icon} · ${next.data.title}`} →</a>
    ) : (
      <a href="scale" class="text-sm font-semibold transition-colors" style="color: var(--fg-muted);" onmouseover="this.style.color='var(--fg)';" onmouseout="this.style.color='var(--fg-muted)';">{d.nextNav} →</a>
    )}
  </div>

</Course>
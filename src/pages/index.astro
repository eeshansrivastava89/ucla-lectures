---
import Course from '../layouts/Course.astro';
import { getCollection, getEntry, render } from 'astro:content';
import '../styles/global.css';

const overview = await getEntry('pages', 'overview');
const { Content } = await render(overview);
const d = overview.data;
const h = d.sectionHeadings;
const c = d.copy;
const th = d.tableHeaders;

const lectures = (await getCollection('pages'))
  .filter((p: any) => p.id.startsWith('lecture-'))
  .sort((a: any, b: any) => a.id.localeCompare(b.id));
---
<Course title={`${d.title} — ${d.program}`} current="overview">

  <h1 class="text-4xl font-bold tracking-tight mb-2" style="color: var(--fg);">{d.title}</h1>
  <p class="text-lg font-medium mb-10" style="color: var(--fg-secondary);">{d.subtitle}</p>

  <section class="mb-10">
    <table class="info-table text-sm w-full">
      <tbody>
        {d.info.map((row: any) => (
          <tr class="info-row">
            <td class="info-label">{row.label}</td>
            <td class="info-value" set:html={row.value} />
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.about}</h2>
    <div class="prose-course">
      <Content />
    </div>
  </section>

  <section class="mb-10" id="schedule">
    <h2 class="section-heading">{h.schedule}</h2>
    <p class="text-sm mb-3" style="color: var(--fg-secondary);">{c.scheduleNote}</p>
    <div class="rounded overflow-hidden" style="border: 2px solid var(--border-strong);">
      <table class="data-table">
        <thead><tr>
          {th.schedule.map((col: any) => <th class={col.width || ''}>{col.label}</th>)}
        </tr></thead>
        <tbody>
          {lectures.map((l: any) => {
            const id = l.id.replace('lecture-', '');
            return (
              <tr>
                <td class="font-mono font-bold" style="color: var(--fg);">{l.data.icon}</td>
                <td>
                  <a href={`lectures/${id}`} class="font-semibold transition-colors" style="color: var(--fg);" onmouseover="this.style.color='var(--fg-muted)';" onmouseout="this.style.color='var(--fg)';">{l.data.title}</a>
                  <p class="text-[13px] mt-0.5" style="color: var(--fg-muted);">{l.data.tagline}</p>
                </td>
                <td class="text-[13px] min-w-[180px]" style="color: var(--fg-secondary);">{l.data.deliverable}</td>
                <td class="text-[13px] min-w-[120px]" style="color: var(--fg-muted);">{l.data.tools.join(' · ')}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.assessment}</h2>
    <div class="prose-course"><p style="color: var(--fg-secondary);">{c.assessmentNote}</p></div>
    <div class="rounded overflow-hidden mt-3" style="border: 2px solid var(--border-strong);">
      <table class="data-table">
        <thead><tr>
          {th.assessment.map((col: any) => <th class={col.width || ''}>{col.label}</th>)}
        </tr></thead>
        <tbody>
          {d.assessment.map((row: any) => (
            <tr class:list={[row.highlight && 'font-semibold']} style={row.highlight ? { color: 'var(--fg)' } : { color: 'var(--fg-secondary)' }}>
              <td>{row.component}</td>
              <td class="text-right font-mono font-bold" style="color: var(--fg);">{row.weight}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.domains}</h2>
    <div class="prose-course"><p style="color: var(--fg-secondary);">{c.domainsNote}</p></div>
    <div class="rounded overflow-hidden mt-3" style="border: 2px solid var(--border-strong);">
      <table class="data-table">
        <thead><tr>
          {th.domains.map((col: any) => <th>{col.label}</th>)}
        </tr></thead>
        <tbody>
          {d.domains.map((row: any) => (
            <tr class:list={[row.primary && 'font-semibold']} style={row.primary ? { color: 'var(--fg)' } : { color: 'var(--fg-secondary)' }}>
              <td>
                {row.name}
                {row.primary && <span class="ml-1 text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded font-bold" style="background-color: var(--nav-active-bg); color: var(--nav-active-fg);">{c.defaultBadge}</span>}
              </td>
              <td class="text-[13px]" style="color: var(--fg-secondary);">{row.mlTask}</td>
              <td class="text-[13px]" style="color: var(--fg-secondary);">{row.llmInterface}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.safety}</h2>
    <div class="prose-course mb-3"><p style="color: var(--fg-secondary);">{c.safetyNote}</p></div>
    <div class="grid sm:grid-cols-3 gap-4">
      {d.safety.map((item: any) => (
        <div class="rounded p-4" style="border: 2px solid var(--border-strong);">
          <h3 class="text-sm font-bold mb-1" style="color: var(--fg);">{item.title}</h3>
          <p class="text-[13px]" style="color: var(--fg-secondary);">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.logistics}</h2>
    <table class="info-table text-sm w-full">
      <tbody>
        {d.logistics.map((row: any) => (
          <tr class="info-row">
            <td class="info-label">{row.label}</td>
            <td class="info-value" set:html={row.value} />
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.references}</h2>
    <ul class="text-sm space-y-1" style="color: var(--fg-secondary);">
      {d.references.map((ref: any) => (
        <li><a href={ref.url} style="color: var(--fg);" class="underline underline-offset-4 transition-colors" onmouseover="this.style.textDecorationColor='var(--fg)';" onmouseout="this.style.textDecorationColor='var(--link-decoration)';">{ref.title}</a> — {ref.note}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2 class="section-heading">{h.instructor}</h2>
    <div class="prose-course">
      <p><strong style="color: var(--fg);">{d.instructor}</strong> — <Fragment set:html={d.instructorBio} /></p>
    </div>
  </section>

</Course>
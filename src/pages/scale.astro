---
import Course from '../layouts/Course.astro';
import { getEntry, render } from 'astro:content';
import '../styles/global.css';

const entry = await getEntry('pages', 'scale');
const { Content } = await render(entry);
const d = entry.data;
const h = d.sectionHeadings;
const th = d.tableHeaders;
---
<Course title="FOSS → Scale — MLOps for Business Analytics" current="scale">

  <p class="text-[11px] uppercase tracking-[0.2em] text-neutral-500 font-bold mb-2">{d.pageLabel}</p>
  <h1 class="text-3xl font-bold tracking-tight text-black mb-2">{d.title}</h1>
  <p class="text-neutral-700 font-medium mb-8">{d.subtitle}</p>

  <section class="mb-10">
    <h2 class="section-heading">{h.principles}</h2>
    <div class="grid sm:grid-cols-3 gap-6">
      {d.principles.map((p: any) => (
        <div>
          <span class="font-mono text-sm font-bold text-black">{p.num}</span>
          <h3 class="text-sm font-bold text-black mt-1 mb-1">{p.title}</h3>
          <p class="text-[13px] text-neutral-700">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.stackMap}</h2>
    <div class="prose-course mb-4">
      <Content />
    </div>
    <div class="border-2 border-black rounded overflow-hidden">
      <table class="data-table">
        <thead><tr>
          {th.stackMap.map((col: any) => <th class={col.width || ''}>{col.label}</th>)}
        </tr></thead>
        <tbody>
          {d.stackMap.map((row: any) => (
            <tr>
              <td class="font-mono font-bold text-black">{row.foss}</td>
              <td class="text-[13px] text-neutral-700">{row.enterprise}</td>
              <td class="font-mono text-neutral-500">{row.lecture}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.scaleChanges}</h2>
    <ul class="space-y-2">
      {d.scaleChanges.map((item: any) => (
        <li class="flex items-start gap-3 text-[15px] text-neutral-800">
          <span class="w-2 h-2 rounded-full bg-black mt-1.5 shrink-0"></span>
          <strong class="text-black">{item.title}</strong> — {item.desc}
        </li>
      ))}
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="section-heading">{h.walkAway}</h2>
    <div class="border-2 border-black bg-black rounded p-5">
      <ul class="space-y-2">
        {d.walkAway.map((item: string) => (
          <li class="flex items-start gap-3 text-[15px] text-white">
            <span class="w-2 h-2 rounded-full bg-white mt-1.5 shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <div class="flex justify-between items-center pt-8 border-t-2 border-black">
    <a href="/lectures/5" class="text-sm text-neutral-700 hover:text-black font-semibold transition-colors">{d.prevNav}</a>
    <a href="/" class="text-sm text-neutral-700 hover:text-black font-semibold transition-colors">{d.nextNav}</a>
  </div>

</Course>
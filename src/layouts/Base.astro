<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <base href="/ucla-lectures/" />
  <link rel="icon" type="image/svg+xml" href="favicon.svg" />
  <title>{Astro.props.title}</title>
  <style is:raw>
    :root {
      --bg: #ffffff;
      --bg-sidebar: #ffffff;
      --bg-hover: #fafafa;
      --bg-inset: #f5f5f5;
      --bg-card: #111111;
      --fg: #111111;
      --fg-secondary: #444444;
      --fg-muted: #737373;
      --fg-faint: #a3a3a3;
      --border: #e5e5e5;
      --border-strong: #111111;
      --selection-bg: #111;
      --selection-fg: #fff;
      --link-decoration: #a3a3a3;
      --nav-active-bg: #111111;
      --nav-active-fg: #ffffff;
      --nav-hover-fg: #111111;
      --nav-hover-bg: #f5f5f5;
      --dot-color: #111111;
    }
    .dark {
      --bg: #0a0a0a;
      --bg-sidebar: #111111;
      --bg-hover: #1a1a1a;
      --bg-inset: #1a1a1a;
      --bg-card: #e5e5e5;
      --fg: #e5e5e5;
      --fg-secondary: #a3a3a3;
      --fg-muted: #737373;
      --fg-faint: #525252;
      --border: #2a2a2a;
      --border-strong: #e5e5e5;
      --selection-bg: #e5e5e5;
      --selection-fg: #0a0a0a;
      --link-decoration: #525252;
      --nav-active-bg: #e5e5e5;
      --nav-active-fg: #0a0a0a;
      --nav-hover-fg: #e5e5e5;
      --nav-hover-bg: #1a1a1a;
      --dot-color: #e5e5e5;
    }
  </style>
  <script is:raw>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="antialiased" style="background-color: var(--bg); color: var(--fg);">
  <slot />
</body>
</html>